// PairingScreen — faithful reproduction of ui_PairingScreen.
// Restored to support BLE scan list when is-ble-scan is true.

import { Theme } from "theme.slint";
import { AppButton } from "app-button.slint";
import { PageFooter } from "page-footer.slint";

export struct DiscoveredDevice {
    name: string,
    index: int,
}

export component PairingScreen inherits Rectangle {
    in property <string> pairing-code: "----";
    in property <string> action-text: "Cancel";
    in property <string> pairing-status: "Searching for board...";
    in property <bool> is-ble-scan: false;
    in property <[DiscoveredDevice]> discovered-devices: [];
    callback action;
    callback select-device(int);
    background: Theme.bg;

    VerticalLayout {
        // ui_PairingBody (75%)
        Rectangle {
            vertical-stretch: 75;
            padding-left: Theme.page-padding-horizontal;
            padding-right: Theme.page-padding-horizontal;
            padding-top: Theme.page-padding-vertical;
            padding-bottom: Theme.page-padding-vertical;

            if !root.is-ble-scan: VerticalLayout {
                alignment: center;
                Text {
                    text: root.pairing-code;
                    color: Theme.text;
                    font-size: Theme.font-48;
                    font-weight: Theme.w-semibold;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Your pairing code";
                    color: Theme.text;
                    font-size: Theme.font-14;
                    horizontal-alignment: center;
                }

                Text {
                    text: root.pairing-status;
                    color: Theme.text;
                    font-size: Theme.font-14;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            if root.is-ble-scan: VerticalLayout {
                alignment: start;
                padding-top: Theme.page-padding-vertical;
                spacing: 8px * Theme.scale;

                Text {
                    text: "Select BLE Device";
                    color: Theme.text;
                    font-size: Theme.font-14;
                    font-weight: Theme.w-semibold;
                    horizontal-alignment: center;
                }

                if root.discovered-devices.length == 0: VerticalLayout {
                    alignment: center;
                    Text {
                        text: "Scanning for boards...";
                        color: Theme.text-dim;
                        font-size: Theme.font-12;
                        horizontal-alignment: center;
                    }
                }

                if root.discovered-devices.length > 0: Flickable {
                    viewport-height: devices-layout.min-height;
                    devices-layout := VerticalLayout {
                        spacing: 6px * Theme.scale;
                        alignment: start;
                        for device in root.discovered-devices: AppButton {
                            height: 32px * Theme.scale;
                            text: device.name;
                            variant: "secondary";
                            clicked => { root.select-device(device.index); }
                        }
                    }
                }
            }
        }

        // ui_PairingFooter (25%)
        PageFooter {
            AppButton {
                text: root.action-text;
                clicked => { root.action(); }
            }
        }
    }
}
