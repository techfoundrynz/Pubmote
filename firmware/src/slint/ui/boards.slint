import { Theme } from "theme.slint";
import { AppButton } from "app-button.slint";
import { PageFooter } from "page-footer.slint";

export struct PairedBoard {
    mac: string,
    index: int,
    is-active: bool,
}

export component BoardsScreen inherits Rectangle {
    in property <[PairedBoard]> boards: [];
    callback select-board(int);
    callback delete-board(int);
    callback pair-new;
    callback back;

    background: Theme.bg;

    VerticalLayout {
        // Header (15% of screen height)
        Rectangle {
            vertical-stretch: 15;
            Text {
                text: "Paired Boards";
                color: Theme.text;
                font-size: Theme.font-14;
                font-weight: Theme.w-semibold;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // List body (60% of screen height)
        Rectangle {
            vertical-stretch: 60;
            padding-left: Theme.page-padding-horizontal;
            padding-right: Theme.page-padding-horizontal;

            if root.boards.length == 0: VerticalLayout {
                alignment: center;
                Text {
                    text: "No boards paired";
                    color: Theme.text-dim;
                    font-size: Theme.font-12;
                    horizontal-alignment: center;
                }
            }

            if root.boards.length > 0: Flickable {
                viewport-height: boards-layout.min-height;
                boards-layout := VerticalLayout {
                    spacing: 8px * Theme.scale;
                    alignment: start;

                    for board in root.boards: HorizontalLayout {
                        spacing: 8px * Theme.scale;
                        height: 38px * Theme.scale;

                        AppButton {
                            horizontal-stretch: 1;
                            text: board.mac;
                            right-text: board.is-active ? "✓" : "";
                            variant: board.is-active ? "primary" : "secondary";
                            clicked => { root.select-board(board.index); }
                        }

                        AppButton {
                            width: 54px * Theme.scale;
                            text: "Delete";
                            variant: "outline";
                            button-color: "danger";
                            clicked => { root.delete-board(board.index); }
                        }
                    }
                }
            }
        }

        // Footer (25% of screen height)
        PageFooter {
            vertical-stretch: 25;
            AppButton {
                text: "Back";
                variant: "secondary";
                clicked => { root.back(); }
            }

            AppButton {
                text: "Pair New";
                clicked => { root.pair-new(); }
            }
        }
    }
}
