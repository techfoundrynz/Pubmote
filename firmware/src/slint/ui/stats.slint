// StatsScreen — main riding display. Faithful reproduction of ui_StatsScreen.
//
// LVGL hierarchy:
//   ui_SpeedDial        lv_arc 240x240, range 0-40, default angles (135->45)
//   ui_UtilizationDial  lv_arc 240x240, pad 20, REVERSE, track 0x282828, w12
//   ui_LeftSensor       lv_arc, bg angles 93-105, track 0x414141, indic white
//   ui_RightSensor      lv_arc, bg angles 75-87,  track 0x414141, indic white
//   ui_StatsContent     flex column SPACE_BETWEEN, pad 20/20/20/5
//     ui_StatsHeader  (25%)  column align end
//       ui_RemoteIndicatorContainer  row: battery pill + RSSI bars (RSSI hidden)
//       ui_MessageText  "PUSHBACK" (hidden)
//     ui_StatsBody    (50%)  column center
//       ui_RemoteModeContainer "POCKET MODE" (hidden)
//       ui_PrimaryStat "0.0" Inter_Bold_48  + ui_PrimaryStatUnit "KPH" Inter_14
//       ui_SecondaryStatContainer  -> ui_ConnectionStateLabel "Disconnected"
//     ui_StatsFooter  (25%)  ui_BoardBatteryDisplay "0%" Inter_Bold_14

import { Theme } from "theme.slint";
import { RoundStats } from "round-stats.slint";
import { SquareStats } from "square-stats.slint";

export component StatsScreen inherits Rectangle {
    in property <bool> square-mode: Theme.is-square-mode;
    in property <string> speed: "0.0";
    in property <string> speed-unit: "KPH";
    in property <float> speed-fraction: 0;       // 0..1 of the speed dial
    in property <float> duty-fraction: 0;        // 0..1 of the utilization dial
    in property <bool> left-pad: false;
    in property <bool> right-pad: false;
    in property <int> remote-battery: 100;       // 0..100, small battery pill
    in property <bool> remote-charging: false;   // is remote charging
    in property <bool> is-connected: false;
    in property <string> connection-state-label: "Disconnected";
    in property <string> board-battery: "0%";
    in property <int> rssi-bars: 0;
    in property <bool> pocket-mode-active: false;
    in property <string> board-state-message: "";
    callback board-battery-long-pressed();

    in property <string> stat-page1: "0.0V";
    in property <string> stat-page2: "0.0A";
    in property <string> stat-page3: "0°C";
    
    in property <[string]> pages: [
        root.stat-page1,
        root.stat-page2,
        root.stat-page3
    ];
    
    property <int> active-page: 0;

    callback swiped-down;

    background: Theme.bg;

    // Swipe down detection
    TouchArea {
        width: 100%;
        height: 100%;
        property <length> start-y;
        property <length> start-x;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left) {
                if (event.kind == PointerEventKind.down) {
                    start-x = self.mouse-x;
                    start-y = self.mouse-y;
                } else if (event.kind == PointerEventKind.up) {
                    let dx = self.mouse-x - start-x;
                    let dy = self.mouse-y - start-y;
                    let abs_dx = dx > 0px ? dx : -dx;
                    let abs_dy = dy > 0px ? dy : -dy;
                    if (dy > 40px && dy > abs_dx) {
                        root.swiped-down();
                    } else if (dx > 40px && dx > abs_dy) {
                        // swipe right (previous page)
                        root.active-page = Math.mod(root.active-page - 1 + root.pages.length, root.pages.length);
                    } else if (dx < -40px && -dx > abs_dy) {
                        // swipe left (next page)
                        root.active-page = Math.mod(root.active-page + 1, root.pages.length);
                    }
                }
            }
        }
    }

    if !root.square-mode : RoundStats {
        width: 100%;
        height: 100%;
        speed: root.speed;
        speed-unit: root.speed-unit;
        speed-fraction: root.speed-fraction;
        duty-fraction: root.duty-fraction;
        left-pad: root.left-pad;
        right-pad: root.right-pad;
        remote-battery: root.remote-battery;
        remote-charging: root.remote-charging;
        is-connected: root.is-connected;
        connection-state-label: root.connection-state-label;
        board-battery: root.board-battery;
        rssi-bars: root.rssi-bars;
        pocket-mode-active: root.pocket-mode-active;
        board-state-message: root.board-state-message;
        active-page: root.active-page;
        pages: root.pages;
        board-battery-long-pressed => {
            root.board-battery-long-pressed();
        }
    }

    if root.square-mode : SquareStats {
        width: 100%;
        height: 100%;
        speed: root.speed;
        speed-unit: root.speed-unit;
        speed-fraction: root.speed-fraction;
        duty-fraction: root.duty-fraction;
        left-pad: root.left-pad;
        right-pad: root.right-pad;
        remote-battery: root.remote-battery;
        remote-charging: root.remote-charging;
        is-connected: root.is-connected;
        connection-state-label: root.connection-state-label;
        board-battery: root.board-battery;
        rssi-bars: root.rssi-bars;
        pocket-mode-active: root.pocket-mode-active;
        board-state-message: root.board-state-message;
        active-page: root.active-page;
        pages: root.pages;
        board-battery-long-pressed => {
            root.board-battery-long-pressed();
        }
    }
}

export component StatsScreenPreview inherits Window {
    width: 466px;
    height: 466px;
    minimized: false;
    StatsScreen {
        square-mode: false;
        speed: "25.4";
        speed-fraction: 0.6;
        duty-fraction: 0.45;
        left-pad: true;
        right-pad: false;
        is-connected: true;
        board-battery: "85%";
        pocket-mode-active: true;
    }
}
