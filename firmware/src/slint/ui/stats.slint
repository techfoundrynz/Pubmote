// StatsScreen — main riding display. Faithful reproduction of ui_StatsScreen.
//
// LVGL hierarchy:
//   ui_SpeedDial        lv_arc 240x240, range 0-40, default angles (135->45)
//   ui_UtilizationDial  lv_arc 240x240, pad 20, REVERSE, track 0x282828, w12
//   ui_LeftSensor       lv_arc, bg angles 93-105, track 0x414141, indic white
//   ui_RightSensor      lv_arc, bg angles 75-87,  track 0x414141, indic white
//   ui_StatsContent     flex column SPACE_BETWEEN, pad 20/20/20/5
//     ui_StatsHeader  (25%)  column align end
//       ui_RemoteIndicatorContainer  row: battery pill + RSSI bars (RSSI hidden)
//       ui_MessageText  "PUSHBACK" (hidden)
//     ui_StatsBody    (50%)  column center
//       ui_RemoteModeContainer "POCKET MODE" (hidden)
//       ui_PrimaryStat "0.0" Inter_Bold_48  + ui_PrimaryStatUnit "KPH" Inter_14
//       ui_SecondaryStatContainer  -> ui_ConnectionStateLabel "Disconnected"
//     ui_StatsFooter  (25%)  ui_BoardBatteryDisplay "0%" Inter_Bold_14

import { Theme } from "theme.slint";
import { ArcGauge } from "arc-gauge.slint";
import { BatteryIndicator } from "battery-indicator.slint";

export component StatsScreen inherits Rectangle {
    in property <string> speed: "0.0";
    in property <string> speed-unit: "KPH";
    in property <float> speed-fraction: 0;       // 0..1 of the speed dial
    in property <float> duty-fraction: 0;        // 0..1 of the utilization dial
    in property <bool> left-pad: false;
    in property <bool> right-pad: false;
    in property <int> remote-battery: 100;       // 0..100, small battery pill
    in property <bool> remote-charging: false;   // is remote charging
    in property <bool> is-connected: false;
    in property <string> connection-state-label: "Disconnected";
    in property <string> board-battery: "0%";

    in property <string> stat-page1: "0.0V";
    in property <string> stat-page2: "0.0A";
    in property <string> stat-page3: "0°C";
    
    in property <[string]> pages: [
        root.stat-page1,
        root.stat-page2,
        root.stat-page3
    ];
    
    property <int> active-page: 0;

    property <brush> duty-color: root.duty-fraction >= 0.90 ? Theme.color-critical : 
        root.duty-fraction >= 0.80 ? Theme.color-warning : 
        root.duty-fraction >= 0.70 ? Theme.color-caution : 
        Theme.color-active;

    callback swiped-down;

    background: Theme.bg;

    // --- Dials (centered, drawn first so the content sits on top) ---
    // ui_SpeedDial: full-size arc (240 of 240 base == 100% of panel).
    ArcGauge {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: parent.height;
        thickness: 16px * Theme.scale;
        start-angle: 140deg;
        span-angle: 260deg;
        track-color: Theme.track;
        indicator-color: Theme.accent;
        value: root.speed-fraction;
    }

    // ui_UtilizationDial
    ArcGauge {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width - (36px * Theme.scale);
        height: parent.height - (36px * Theme.scale);
        thickness: 12px * Theme.scale;
        start-angle: 140deg;
        span-angle: 260deg;
        track-color: Theme.track-dim;
        indicator-color: root.duty-color;
        reverse: true;
        value: root.duty-fraction;
    }

    // ui_LeftSensor
    ArcGauge {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: parent.height;
        thickness: 10px * Theme.scale;
        start-angle: 93deg;
        span-angle: 12deg;
        track-color: Theme.track;
        indicator-color: Theme.text;
        value: root.left-pad && root.is-connected ? 1.0 : 0.0;
        show-track: root.is-connected;
    }

    // ui_RightSensor
    ArcGauge {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: parent.height;
        thickness: 10px * Theme.scale;
        start-angle: 75deg;
        span-angle: 12deg;
        track-color: Theme.track;
        indicator-color: Theme.text;
        value: root.right-pad && root.is-connected ? 1.0 : 0.0;
        show-track: root.is-connected;
    }

    // --- Content overlay (ui_StatsContent) ---
    VerticalLayout {
        padding-left: 20px * Theme.scale;
        padding-right: 20px * Theme.scale;
        padding-top: 20px * Theme.scale;
        padding-bottom: 5px * Theme.scale;

        // ui_StatsHeader (25%) — indicators pinned to the bottom of the region.
        Rectangle {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: end;
                // ui_RemoteIndicatorContainer
                HorizontalLayout {
                    alignment: center;
                    // ui_BatteryIndicatorContainer (outline + fill + tip).
                    BatteryIndicator {
                        battery: root.remote-battery;
                        charging: root.remote-charging;
                    }
                }
            }
        }

        // ui_StatsBody (50%)
        Rectangle {
            vertical-stretch: 2;
            VerticalLayout {
                alignment: center;
                // ui_PrimaryStat + ui_PrimaryStatUnit
                HorizontalLayout {
                    alignment: center;
                    spacing: 4px;
                    Rectangle {
                        width: unit-text.preferred-width;
                    }
                    Text {
                        text: root.speed;
                        color: Theme.text;
                        font-size: Theme.font-96;
                        font-weight: Theme.w-bold;
                        vertical-alignment: center;
                    }
                    VerticalLayout {
                        alignment: end;
                        padding-bottom: 10px * Theme.scale;
                        unit-text := Text {
                            text: root.speed-unit;
                            color: Theme.text;
                            font-size: Theme.font-14;
                        }
                    }
                }
                // ui_SecondaryStatContainer -> ui_ConnectionStateLabel
                Text {
                    text: root.is-connected ? root.pages[root.active-page] : root.connection-state-label;
                    color: Theme.text;
                    font-size: Theme.font-14;
                    horizontal-alignment: center;
                }
            }
        }

        // ui_StatsFooter (25%)
        Rectangle {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: center;
                Text {
                    text: root.board-battery;
                    color: Theme.text;
                    font-size: Theme.font-14;
                    font-weight: Theme.w-bold;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // Swipe down detection
    TouchArea {
        width: 100%;
        height: 100%;
        property <length> start-y;
        property <length> start-x;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left) {
                if (event.kind == PointerEventKind.down) {
                    start-x = self.mouse-x;
                    start-y = self.mouse-y;
                } else if (event.kind == PointerEventKind.up) {
                    let dx = self.mouse-x - start-x;
                    let dy = self.mouse-y - start-y;
                    let abs_dx = dx > 0px ? dx : -dx;
                    let abs_dy = dy > 0px ? dy : -dy;
                    if (dy > 40px && dy > abs_dx) {
                        root.swiped-down();
                    } else if (dx > 40px && dx > abs_dy) {
                        // swipe right (previous page)
                        root.active-page = Math.mod(root.active-page - 1 + root.pages.length, root.pages.length);
                    } else if (dx < -40px && -dx > abs_dy) {
                        // swipe left (next page)
                        root.active-page = Math.mod(root.active-page + 1, root.pages.length);
                    }
                }
            }
        }
    }
}
