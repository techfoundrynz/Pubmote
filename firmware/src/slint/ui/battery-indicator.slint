import { Theme } from "theme.slint";

export component BatteryIndicator inherits Rectangle {
    in property <int> battery: 100;
    in property <bool> charging: false;

    width: 24px * Theme.scale;
    height: 14px * Theme.scale;

    // ui_BatteryOutline + ui_BatteryFill
    Rectangle {
        x: 0;
        y: 0;
        width: 21px * Theme.scale;
        height: 14px * Theme.scale;
        border-radius: 4px * Theme.scale;
        border-width: 1.5px * Theme.scale;
        border-color: Theme.text;
        
        Rectangle {
            x: 2px * Theme.scale;
            y: 2px * Theme.scale;
            width: (parent.width - 4px * Theme.scale) * clamp(root.battery / 100.0, 0, 1);
            height: parent.height - 4px * Theme.scale;
            border-radius: 2px * Theme.scale;
            background: root.charging ? Theme.battery-green : (root.battery > 50 ? Theme.battery-green : (root.battery > 20 ? Theme.battery-yellow : Theme.battery-red));
        }

        if root.charging: Path {
            width: 6px * Theme.scale;
            height: 10px * Theme.scale;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            viewbox-width: 6;
            viewbox-height: 10;
            fill: Theme.bg;
            commands: "M 3 0 L 0 5.5 L 3 5.5 L 2 10 L 6 4.5 L 3 4.5 Z";
        }
    }

    // ui_BatteryTip
    Rectangle {
        x: 20px * Theme.scale;
        y: (parent.height - self.height) / 2;
        width: 3px * Theme.scale;
        height: 5px * Theme.scale;
        border-radius: 1.5px * Theme.scale;
        background: Theme.text;
    }
}
