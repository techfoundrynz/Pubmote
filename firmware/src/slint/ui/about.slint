// AboutScreen — faithful reproduction of ui_AboutScreen.
//
// LVGL: ui_AboutContent (column SPACE_BETWEEN)
//   ui_AboutHeader (20%)  (empty row)
//   ui_AboutBody   (55%, horizontal-scroll row of two pages):
//       ui_VersionInfoContainer -> ui_VersionInfoLabel
//             "Version: unknown\nType: unknown\nHash: unknown"
//             ui_UpdateButton (outlined) "Check for updates"
//       ui_DebugInfoContainer   -> ui_DebugInfoLabel "Battery: unknown"
//   ui_AboutFooter (25%) -> ui_AboutMainActionButton 80x42 "Back"

import { Theme } from "theme.slint";
import { AppButton } from "app-button.slint";
import { PageFooter } from "page-footer.slint";
import { Pager } from "pager.slint";

export component AboutScreen inherits Rectangle {
    in property <string> version-info: "Version: unknown\nType: unknown\nHash: unknown";
    in property <string> debug-info: "Battery: unknown";
    callback check-updates;
    callback back;
    background: Theme.bg;

    property <int> current-page: 0;

    VerticalLayout {
        Pager {
            current-page <=> root.current-page;
            total-pages: 2;

            // Page 1: version + update button
            Rectangle {
                width: root.width;
                background: Theme.bg;
                VerticalLayout {
                    padding-left: 40px * Theme.scale;
                    padding-right: 40px * Theme.scale;
                    spacing: 10px * Theme.scale;
                    alignment: center;
                    Text {
                        text: root.version-info;
                        color: Theme.text;
                        font-size: Theme.font-14;
                        horizontal-alignment: center;
                    }

                    AppButton {
                        variant: "outline";
                        size: "small";
                        text: "Check for updates";
                        clicked => { root.check-updates(); }
                    }
                }
            }
            // Page 2: debug info
            Rectangle {
                width: root.width;
                background: Theme.bg;
                VerticalLayout {
                    padding-left: 40px * Theme.scale;
                    padding-right: 40px * Theme.scale;
                    alignment: center;
                    Text {
                        text: root.debug-info;
                        color: Theme.text;
                        font-size: Theme.font-14;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // ui_AboutFooter (25%)
        PageFooter {
            AppButton {
                text: "Back";
                clicked => { root.back(); }
            }
        }
    }
}
