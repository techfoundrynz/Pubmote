import { Theme } from "theme.slint";

// Common touch button component with variant and size options.
export component AppButton inherits Rectangle {
    in property <string> text;
    in property <string> variant: "primary"; // "primary", "secondary", "outline"
    in property <string> size: "medium";     // "medium", "small"
    in property <bool> enabled: true;
    callback clicked;
    callback long-clicked;
    property <bool> was-long-pressed: false;

    // Height based on size
    height: root.size == "small" ? 32px * Theme.scale : 42px * Theme.scale;
    border-radius: 8px * Theme.scale;
    
    // Border for outline variant
    border-width: root.variant == "outline" ? 2px : 0px;
    border-color: root.variant == "outline" ? Theme.text : transparent;

    // Background color based on variant and state
    background: !root.enabled ? Theme.track :
        root.variant == "outline" ? (touch.pressed ? #ffffff20 : transparent) :
        root.variant == "secondary" ? (touch.pressed ? Theme.track.darker(0.2) : Theme.track) :
        // default/primary
        (touch.pressed ? Theme.accent.darker(0.2) : Theme.accent);

    Text {
        text: root.text;
        color: !root.enabled ? Theme.text-dim :
            root.variant == "outline" ? Theme.text :
            root.variant == "secondary" ? Theme.text :
            // default/primary
            Theme.primary-button-text;
        font-size: Theme.font-14;
        font-weight: Theme.w-semibold;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            if (!root.was-long-pressed) {
                root.clicked();
            }
        }
        pointer-event(event) => {
            if (event.button == PointerEventButton.left) {
                if (event.kind == PointerEventKind.down) {
                    root.was-long-pressed = false;
                    long-press-timer.running = true;
                } else if (event.kind == PointerEventKind.up) {
                    long-press-timer.running = false;
                }
            }
        }
    }

    long-press-timer := Timer {
        interval: 800ms;
        running: false;
        triggered => {
            self.running = false;
            root.was-long-pressed = true;
            root.long-clicked();
        }
    }
}
