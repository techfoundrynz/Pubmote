// CalibrationScreen — faithful reproduction of ui_CalibrationScreen.
//
// LVGL: ui_CalibrationContent (column SPACE_BETWEEN)
//   ui_CalibrationHeader (20%) -> "X: 0.0 | Y: 0.0" Inter_Bold_14
//   ui_CalibrationBody   (55%, row gap 12) -> ui_CalibrationStepContent (90%):
//       ui_CalibrationIndicatorContainer  80x80 circle, border 0x414141 w6
//         ui_CalibrationLineVert   4 x 130%  red 0xEE4266 (crosshair)
//         ui_CalibrationLineHoriz  130% x 4  red 0xEE4266
//         ui_PositionIndicatorContainer 20%x20% -> white cross (live position)
//       ui_CalibrationStepLabel "Press start to begin calibration" Inter_14
//   ui_CalibrationFooter (25%) -> Secondary 60x42 "Cancel" + Primary 60x42 "Start"

import { Theme } from "theme.slint";
import { AppButton } from "app-button.slint";
import { AppSlider } from "app-slider.slint";
import { AppSwitch } from "app-switch.slint";
import { PageFooter } from "page-footer.slint";
import { JoystickDial } from "joystick-dial.slint";

export component InputCalibrationScreen inherits Rectangle {
    in property <string> readout-text: "X: 0.0 | Y: 0.0";
    in property <string> step-text: "Press start to begin calibration";
    in property <string> primary-text: "Start";
    in property <float> joystick-x: 0;   // -1..1
    in property <float> joystick-y: 0;   // -1..1
    in property <bool> show-expo-slider: false;
    in property <bool> show-invert-switch: false;
    in-out property <float> expo-value: 1.0;
    in-out property <bool> invert-y: false;
    callback primary;
    callback secondary;
    background: Theme.bg;

    property <length> dial: Math.round((90px * Theme.scale) / 1px) * 1px;

    VerticalLayout {
        padding-top: Theme.page-padding-vertical;

        // ui_CalibrationBody (75%)
        VerticalLayout {
            alignment: center;
            vertical-stretch: 75;
            spacing: 12px * Theme.scale;

            // ui_CalibrationIndicatorContainer (80x80 circle)
            if !root.show-expo-slider && !root.show-invert-switch: HorizontalLayout {
                alignment: center;
                JoystickDial {
                    joystick-x: root.joystick-x;
                    joystick-y: root.joystick-y;
                    dial-size: root.dial;
                }
            }

            if root.show-expo-slider: Rectangle {
                width: 100%;
                height: root.dial;
                AppSlider {
                    width: 80%;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    minimum: 1.0;
                    maximum: 5.0;
                    value <=> root.expo-value;
                }
            }

            if root.show-invert-switch: Rectangle {
                width: 100%;
                height: root.dial;
                AppSwitch {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    checked <=> root.invert-y;
                }
            }

            // ui_CalibrationStepLabel & Readout Group
            VerticalLayout {
                spacing: 6px * Theme.scale;
                alignment: center;

                Text {
                    text: root.readout-text;
                    color: Theme.text;
                    font-size: Theme.font-12;
                    font-family: "JetBrains Mono";
                    horizontal-alignment: center;
                }

                Text {
                    width: 100%;
                    text: root.step-text;
                    color: Theme.text-dim;
                    font-size: Theme.font-12;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }

        // ui_CalibrationFooter (25%)
        PageFooter {
            AppButton {
                text: "Cancel";
                variant: "secondary";
                clicked => { root.secondary(); }
            }

            AppButton {
                text: root.primary-text;
                clicked => { root.primary(); }
            }
        }
    }
}
