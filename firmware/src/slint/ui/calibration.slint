// CalibrationScreen — faithful reproduction of ui_CalibrationScreen.
//
// LVGL: ui_CalibrationContent (column SPACE_BETWEEN)
//   ui_CalibrationHeader (20%) -> "X: 0.0 | Y: 0.0" Inter_Bold_14
//   ui_CalibrationBody   (55%, row gap 12) -> ui_CalibrationStepContent (90%):
//       ui_CalibrationIndicatorContainer  80x80 circle, border 0x414141 w6
//         ui_CalibrationLineVert   4 x 130%  red 0xEE4266 (crosshair)
//         ui_CalibrationLineHoriz  130% x 4  red 0xEE4266
//         ui_PositionIndicatorContainer 20%x20% -> white cross (live position)
//       ui_CalibrationStepLabel "Press start to begin calibration" Inter_14
//   ui_CalibrationFooter (25%) -> Secondary 60x42 "Cancel" + Primary 60x42 "Start"

import { Theme } from "theme.slint";
import { AppButton } from "app-button.slint";
import { AppSlider } from "app-slider.slint";
import { AppSwitch } from "app-switch.slint";
import { PageFooter } from "page-footer.slint";

export component CalibrationScreen inherits Rectangle {
    in property <string> header-text: "X: 0.0 | Y: 0.0";
    in property <string> step-text: "Press start to begin calibration";
    in property <string> primary-text: "Start";
    in property <float> joystick-x: 0;   // -1..1
    in property <float> joystick-y: 0;   // -1..1
    in property <bool> show-expo-slider: false;
    in property <bool> show-invert-switch: false;
    in-out property <float> expo-value: 1.0;
    in-out property <bool> invert-y: false;
    callback primary;
    callback secondary;
    background: Theme.bg;

    property <length> dial: 60px * Theme.scale;

    VerticalLayout {
        // ui_CalibrationHeader (20%)
        Rectangle {
            vertical-stretch: 20;
            VerticalLayout {
                alignment: center;
                Text {
                    text: root.header-text;
                    color: Theme.text;
                    font-size: Theme.font-12;
                    font-weight: Theme.w-medium;
                    font-family: "JetBrains Mono";
                    horizontal-alignment: center;
                }
            }
        }

        // ui_CalibrationBody (55%)
        VerticalLayout {
            alignment: center;
            vertical-stretch: 55;
            spacing: 12px * Theme.scale;

            // ui_CalibrationIndicatorContainer (80x80 circle)
            if !root.show-expo-slider && !root.show-invert-switch: HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: root.dial;
                    height: root.dial;
                    border-radius: self.width / 2;
                    border-width: 6px;
                    border-color: Theme.track;

                    // ui_CalibrationLineVert (red crosshair, overflows 130%)
                    Rectangle {
                        width: 4px;
                        height: parent.height * 1.3;
                        background: Theme.color-critical;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    // ui_CalibrationLineHoriz
                    Rectangle {
                        width: parent.width * 1.3;
                        height: 4px;
                        background: Theme.color-critical;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    // ui_PositionIndicatorContainer (live white cross, 20% size)
                    Rectangle {
                        width: parent.width * 0.2;
                        height: parent.height * 0.2;
                        // Move within the dial proportionally to the stick.
                        x: (parent.width - self.width) / 2
                            + clamp(root.joystick-x, -1, 1) * (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2
                            + clamp(root.joystick-y, -1, 1) * (parent.height - self.height) / 2;
                        Rectangle {
                            width: 100%;
                            height: 4px;
                            background: Theme.text;
                            y: (parent.height - self.height) / 2;
                        }

                        Rectangle {
                            width: 4px;
                            height: 100%;
                            background: Theme.text;
                            x: (parent.width - self.width) / 2;
                        }
                    }
                }
            }

            if root.show-expo-slider: Rectangle {
                width: 100%;
                height: root.dial;
                AppSlider {
                    width: 80%;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    minimum: 1.0;
                    maximum: 5.0;
                    value <=> root.expo-value;
                }
            }

            if root.show-invert-switch: Rectangle {
                width: 100%;
                height: root.dial;
                AppSwitch {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    checked <=> root.invert-y;
                }
            }

            // ui_CalibrationStepLabel
            Text {
                width: 100%;
                text: root.step-text;
                color: Theme.text;
                font-size: Theme.font-12;
                font-weight: Theme.w-medium;
                font-family: "JetBrains Mono";
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }

        // ui_CalibrationFooter (25%)
        PageFooter {
            AppButton {
                text: "Cancel";
                variant: "secondary";
                clicked => { root.secondary(); }
            }

            AppButton {
                text: root.primary-text;
                clicked => { root.primary(); }
            }
        }
    }
}
