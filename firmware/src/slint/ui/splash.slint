// SplashScreen — centered Pubmote logo on black, tap to continue.
// LVGL: ui_SplashScreen -> ui_SplashScreenLogo (ui_img_icon2_png), centered;
// the screen advances to Stats on load (here: on tap).

import { Theme } from "theme.slint";

export component SplashScreen inherits Rectangle {
    callback clicked;
    background: Theme.bg;

    Image {
        width: 120px * Theme.scale;
        height: 120px * Theme.scale;
        source: @image-url("../../../assets/icon2.png");
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}
