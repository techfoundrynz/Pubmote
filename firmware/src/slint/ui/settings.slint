// SettingsScreen — faithful reproduction of ui_SettingsScreen.
//
// LVGL: ui_SettingsContent (column SPACE_BETWEEN)
//   ui_SettingsHeader (20%) (empty row)
//   ui_SettingsBody   (55%) — a HORIZONTAL, snap-scrolled row of setting "pages",
//     each a full-width column with a control and a label below it:
//       Brightness slider (10..255)         "Screen brightness"
//       Double-press dropdown (None/Open menu) "Double-press action"
//       Rotation dropdown (None/90/180/270)   "Screen rotation"
// SettingsScreen — restored to horizontal pages with snapping and artifact-free rendering

import { Theme } from "theme.slint";
import { AppButton } from "app-button.slint";
import { ComboBox } from "combo-box.slint";
import { AppSwitch } from "app-switch.slint";
import { AppSlider } from "app-slider.slint";
import { ColorSlider } from "color-slider.slint";
import { PageFooter } from "page-footer.slint";
import { Pager } from "pager.slint";

// One settings page: a control slot with a caption below it.
component SettingPage inherits Rectangle {
    in property <string> caption;
    background: Theme.bg;
    
    VerticalLayout {
        alignment: center;
        spacing: round(20px / 1px * Theme.scale) * 1px;
        padding-left: round(20px / 1px * Theme.scale) * 1px;
        padding-right: round(20px / 1px * Theme.scale) * 1px;
        
        Text {
            text: root.caption;
            color: Theme.text;
            font-size: Theme.font-14;
            horizontal-alignment: center;
        }
        
        @children
    }
}

export component SettingsScreen inherits Rectangle {
    in-out property <float> brightness: 128;
    in-out property <int> double-press-index: 0;
    in-out property <int> rotation-index: 0;
    in-out property <int> auto-off-index: 0;
    in-out property <int> temp-units-index: 0;
    in-out property <int> distance-units-index: 0;
    in-out property <int> startup-sound-index: 0;

    
    in-out property <float> theme-h: 0;
    in-out property <float> theme-s: 100;
    in-out property <float> theme-l: 50;
    
    callback save;
    background: Theme.bg;
    
    property <int> current-page: 0;
    property <int> total-pages: 8;

    VerticalLayout {
        Pager {
            current-page <=> root.current-page;
            total-pages: root.total-pages;

            SettingPage {
                width: root.width;
                caption: "Screen brightness";
                AppSlider { minimum: 10; maximum: 255; value <=> root.brightness; }
            }
            SettingPage {
                width: root.width;
                caption: "Double-press action";
                ComboBox {
                    model: ["None", "Open menu"];
                    current-index <=> root.double-press-index;
                }
            }
            SettingPage {
                width: root.width;
                caption: "Screen rotation";
                ComboBox {
                    model: ["None", "90 degrees", "180 degrees", "270 degrees"];
                    current-index <=> root.rotation-index;
                }
            }
            SettingPage {
                width: root.width;
                caption: "Auto-off time";
                ComboBox {
                    model: ["Disabled", "2 minutes", "5 minutes", "10 minutes", "20 minutes", "30 minutes"];
                    current-index <=> root.auto-off-index;
                }
            }
            SettingPage {
                width: root.width;
                caption: "Temp units";
                ComboBox {
                    model: ["Celsius", "Fahrenheit"];
                    current-index <=> root.temp-units-index;
                }
            }
            SettingPage {
                width: root.width;
                caption: "Distance units";
                ComboBox {
                    model: ["Kilometers", "Miles"];
                    current-index <=> root.distance-units-index;
                }
            }
            SettingPage {
                width: root.width;
                caption: "Startup sound";
                ComboBox {
                    model: ["Disabled", "Beep", "Melody"];
                    current-index <=> root.startup-sound-index;
                }
            }
            SettingPage {
                width: root.width;
                caption: "Theme color";
                ColorSlider {
                    hue <=> root.theme-h;
                    sat <=> root.theme-s;
                    lit <=> root.theme-l;
                }
            }
        }

        // Footer
        PageFooter {
            AppButton {
                text: "Save";
                clicked => { root.save(); }
            }
        }
    }
}
