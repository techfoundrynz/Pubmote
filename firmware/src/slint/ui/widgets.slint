// Reusable widgets for the PubRemote Slint UI.

import { Theme } from "theme.slint";

// Arc gauge, the equivalent of LVGL's lv_arc. Draws a background "track" arc and
// an "indicator" arc on top, using SVG-style Path arcs.
//
// Angles follow the LVGL convention: 0deg = 3 o'clock, increasing clockwise
// (90deg = 6 o'clock / bottom). `start-angle` is where the arc begins and
// `span-angle` how far it sweeps clockwise. `value` (0..1) is the filled
// fraction; `reverse` fills from the far end backwards (LVGL ARC_MODE_REVERSE).
//
// The Path viewbox is bound 1:1 to the pixel size (viewbox-width == width/1px),
// so 1 viewbox unit == 1px and stroke-width / radius are in real pixels.
export component ArcGauge inherits Rectangle {
    in property <angle> start-angle: 135deg;   // lv_arc default background start
    in property <angle> span-angle: 270deg;    // lv_arc default 135->45 == 270deg
    in property <float> value: 0;              // 0..1
    in property <bool> reverse: false;
    in property <length> thickness: 16px;
    in property <brush> track-color: Theme.track;
    in property <brush> indicator-color: Theme.accent;
    in property <bool> show-track: true;

    property <float> w: self.width / 1px;
    property <float> h: self.height / 1px;
    property <float> cx: root.w / 2;
    property <float> cy: root.h / 2;
    property <float> rad: max(0.0, root.w / 2 - (root.thickness / 1px) / 2);

    property <brush> trans: transparent;

    // Background track path
    if (root.show-track && root.span-angle > 0deg && root.w > root.thickness / 1px && root.h > root.thickness / 1px) : Path {
        width: 100%;
        height: 100%;
        viewbox-width: root.w;
        viewbox-height: root.h;
        stroke: root.track-color;
        stroke-width: root.thickness;
        stroke-line-cap: round;

        property <angle> angle1: root.start-angle;
        property <angle> angle2: root.start-angle + root.span-angle;

        MoveTo {
            x: root.cx + root.rad * Math.cos(parent.angle1);
            y: root.cy + root.rad * Math.sin(parent.angle1);
        }
        ArcTo {
            radius-x: root.rad;
            radius-y: root.rad;
            x: root.cx + root.rad * Math.cos(parent.angle2);
            y: root.cy + root.rad * Math.sin(parent.angle2);
            large-arc: (parent.angle2 - parent.angle1) > 180deg;
            sweep: true;
        }
    }

    // Active indicator path
    if (root.value > 0.0 && root.span-angle > 0deg && root.w > root.thickness / 1px && root.h > root.thickness / 1px) : Path {
        width: 100%;
        height: 100%;
        viewbox-width: root.w;
        viewbox-height: root.h;
        stroke: root.indicator-color;
        stroke-width: root.thickness;
        stroke-line-cap: round;

        property <angle> active-span: root.span-angle * clamp(root.value, 0.0, 1.0);
        property <angle> angle1: root.reverse ? (root.start-angle + root.span-angle - self.active-span) : root.start-angle;
        property <angle> angle2: self.angle1 + self.active-span;

        MoveTo {
            x: root.cx + root.rad * Math.cos(parent.angle1);
            y: root.cy + root.rad * Math.sin(parent.angle1);
        }
        ArcTo {
            radius-x: root.rad;
            radius-y: root.rad;
            x: root.cx + root.rad * Math.cos(parent.angle2);
            y: root.cy + root.rad * Math.sin(parent.angle2);
            large-arc: (parent.angle2 - parent.angle1) > 180deg;
            sweep: true;
        }
    }
}

// Primary touch button: matches the LVGL lv_btn used across menu/settings/etc.
// (default theme rounded button, 42px tall at base res).
export component AppButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: true;
    in property <bool> enabled: true;
    callback clicked;

    height: 42px * Theme.scale;
    border-radius: 8px;
    background: !root.enabled
        ? Theme.track-dim
        : touch.pressed
            ? Theme.accent.darker(0.2)
            : (root.primary ? Theme.accent : Theme.track-dim);

    Text {
        text: root.text;
        color: root.enabled ? Theme.text : Theme.text-dim;
        font-size: Theme.font-14;
        font-weight: Theme.w-bold;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

// Outlined button (transparent fill, white border) — the LVGL "Check for
// updates" button on the About screen.
export component OutlineButton inherits Rectangle {
    in property <string> text;
    callback clicked;

    height: 32px * Theme.scale;
    border-radius: 8px;
    border-width: 2px;
    border-color: Theme.text;
    background: touch.pressed ? #ffffff20 : transparent;

    Text {
        text: root.text;
        color: Theme.text;
        font-size: Theme.font-14;
        font-weight: Theme.w-bold;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Custom ComboBox without image dependencies (uses a text triangle indicator and PopupWindow).
export component ComboBox inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    callback selected(string);

    height: 36px * Theme.scale;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.track;
    background: Theme.track-dim;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        
        Text {
            text: root.current-index < root.model.length ? root.model[root.current-index] : "";
            color: Theme.text;
            font-size: Theme.font-14;
            vertical-alignment: center;
            horizontal-alignment: left;
        }
        
        Text {
            text: "▼";
            color: Theme.text-dim;
            font-size: Theme.font-14;
            vertical-alignment: center;
            horizontal-alignment: right;
            width: 14px;
        }
    }

    TouchArea {
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: root.width;
        
        Rectangle {
            background: Theme.track-dim;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.track;
            
            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                for item[idx] in root.model : Rectangle {
                    height: 32px * Theme.scale;
                    background: item-touch.pressed ? Theme.accent.darker(0.2) : (idx == root.current-index ? Theme.track : transparent);
                    border-radius: 4px;
                    
                    Text {
                        x: 12px;
                        text: item;
                        color: Theme.text;
                        font-size: Theme.font-14;
                        vertical-alignment: center;
                    }
                    
                    item-touch := TouchArea {
                        clicked => {
                            root.current-index = idx;
                            root.selected(item);
                            popup.close();
                        }
                    }
                }
            }
        }
    }
}

